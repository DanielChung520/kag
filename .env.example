# =============================================================================
# kag — Environment Configuration
# Copy to .env and fill in real values. NEVER commit .env.
# =============================================================================

# ─── Core ──────────────────────────────────────────────────────────────────
KAG_ENV=development                       # development | staging | production
KAG_LOG_LEVEL=INFO                         # DEBUG | INFO | WARNING | ERROR
KAG_API_KEY_PEPPER=__CHANGE_ME__          # 32+ random chars; used for API key hashing. REQUIRED.

# ─── Admin auth (used for KB / Ontology management endpoints) ─────────────
KAG_ADMIN_TOKEN=__CHANGE_ME__             # 32+ random chars. Required for admin endpoints.

# ─── ArangoDB (shared with aibox-th; uses prefixed collections) ───────────
ARANGO_URL=http://localhost:8529
ARANGO_DB=aistock
ARANGO_USER=root
ARANGO_PASSWORD=__CHANGE_ME__

# ─── Qdrant (shared; per-KB collections prefixed kag_kb_) ────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=                            # leave blank for local dev
QDRANT_VECTOR_DIM=1024                     # match embedding model output dim

# ─── SeaweedFS (shared; bucket "kag" with per-KB key prefix) ─────────────
SEAWEED_URL=http://localhost:8888
SEAWEED_BUCKET=kag
SEAWEED_ACCESS_KEY=__CHANGE_ME__
SEAWEED_SECRET_KEY=__CHANGE_ME__

# ─── Redis (Celery broker + result backend) ───────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_TASK_TIME_LIMIT=600                 # hard kill after 10 min

# ─── LLM provider (dllm-first; any OpenAI-compatible server works) ──────
# Base URL MUST include the /v1 suffix. Examples:
#   dllm (preferred):    http://dllm-host:11400/v1
#   vLLM:                http://vllm-host:8000/v1
#   llama.cpp:           http://llamacpp-host:8080/v1
#
# ⚠ Ollama is NOT recommended: it produces non-OpenAI-compatible output in some
#   endpoints (e.g. /v1/embeddings returns inconsistent shapes) and is being
#   deprecated from the team's LLM stack. Use dllm instead.
LLM_BASE_URL=http://localhost:11400/v1
LLM_API_KEY=__CHANGE_ME__                  # bearer token; required by dllm; blank only for dev (insecure)

# ─── Model names (must be pulled on the LLM server) ──────────────────────
# Defaults target a typical dllm deployment; override per your environment.
EMBEDDING_MODEL=bge-m3                    # must produce QDRANT_VECTOR_DIM
GRAPH_MODEL=qwen3-30b-a3b-4bit            # main chat/reasoning; small enough for edge boxes
VLM_MODEL=qwen2.5-vl-8b                   # multimodal for image captioning

# ─── LLM tunables ────────────────────────────────────────────────────────
LLM_TIMEOUT=300.0                          # per-request timeout in seconds
LLM_JSON_RETRY=1                           # retry once on JSON parse failure
LLM_MAX_RETRIES=2                          # total retries (excl. JSON_RETRY)
LLM_TEMPERATURE_GRAPH=0.1                  # low for deterministic extraction
LLM_TEMPERATURE_VL=0.3                     # slightly higher for caption creativity
LLM_MAX_TOKENS_GRAPH=4096
LLM_MAX_TOKENS_VL=1024

# ─── Server / port ────────────────────────────────────────────────────────
# Bind to 127.0.0.1 in production: kag is fronted by Cloudflare Tunnel
# (kag.aiconn.ai → localhost:8800) and should NOT be reachable directly.
# Use 0.0.0.0 only for local development without a tunnel.
KAG_HOST=127.0.0.1
KAG_PORT=8800
KAG_WORKERS=1

# ─── Misc tunables ────────────────────────────────────────────────────────
KAG_FILE_PATH_ALLOWLIST=                   # comma-separated absolute paths; if empty, all allowed
KAG_DOWNLOAD_URL_TTL=3600                  # presigned URL expiry in seconds
KAG_VECTOR_CHUNK_SIZE=512                  # tokens
KAG_VECTOR_CHUNK_OVERLAP=64
KAG_GRAPH_MAX_ENTITIES_PER_FILE=500

# ─── Observability ────────────────────────────────────────────────────────
KAG_TRACING_ENABLED=false
KAG_OTLP_ENDPOINT=                         # e.g., http://localhost:4317 for OTLP gRPC
